---
/**
 * OsmBase - Base component for rendering OpenStreetMap iframe embeds.
 */
interface MapLink {
  href: string;
  label: string;
}

interface Props {
  embedUrl: string;
  title?: string;
  height?: number | string;
  caption?: string;
  links?: MapLink[];
  figureClass?: string;
}

const {
  embedUrl,
  title = "Map",
  height = 320,
  caption,
  links = [],
  figureClass,
} = Astro.props as Props;

const safeHeight = Math.max(200, Math.round(Number(height) || 320));
const className = ["book-osm-map-embed", figureClass].filter(Boolean).join(" ");
---

<figure class={className}>
  <div class="map-frame" style={`--map-height:${safeHeight}px;`}>
    <iframe
      class="map-fallback"
      title={title}
      src={embedUrl}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
    <slot name="overlay" />
  </div>

  {(caption || links.length > 0) && (
    <figcaption>
      <span>{caption}</span>
      {links.length > 0 && (
        <span class="links">
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </span>
      )}
    </figcaption>
  )}
</figure>

<style>
  .book-osm-map-embed {
    margin: 1.5rem 0;
    border: 1px solid var(--gray-200);
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--white);
  }

  .map-frame {
    position: relative;
    height: var(--map-height);
    overflow: hidden;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--gray-100) 85%, white), var(--white));
  }

  .map-fallback {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  figcaption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1rem;
    font-size: var(--font-size-smaller);
    color: var(--gray-500);
    background: var(--gray-100);
  }

  .links {
    display: inline-flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  figcaption a {
    color: var(--color-link);
    text-decoration: none;
    white-space: nowrap;
  }

  figcaption a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 640px) {
    figcaption {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
