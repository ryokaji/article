1---
/**
 * MapMarker - Render a single marker map embed from latitude/longitude.
 */
interface Props {
  lat: number | string;
  lng: number | string;
  zoom?: number;
  height?: number | string;
  title?: string;
  label?: string;
}

const {
  lat,
  lng,
  zoom = 14,
  height = 320,
  title = "Map",
  label,
} = Astro.props;

function parseCoordinate(value: number | string, name: string, min: number, max: number) {
  const numeric = typeof value === "number" ? value : Number(value);

  if (!Number.isFinite(numeric) || numeric < min || numeric > max) {
    throw new Error(`MapMarker: ${name} must be between ${min} and ${max}.`);
  }

  return numeric;
}

function clamp(value: number, min: number, max: number) {
  return Math.min(max, Math.max(min, value));
}

const latitude = parseCoordinate(lat, "lat", -90, 90);
const longitude = parseCoordinate(lng, "lng", -180, 180);
const safeZoom = clamp(Math.round(Number(zoom) || 14), 1, 19);
const safeHeight = Math.max(200, Math.round(Number(height) || 320));

const latSpan = Math.max(180 / 2 ** safeZoom, 0.0025);
const lonSpan = Math.max(latSpan / Math.max(Math.cos((latitude * Math.PI) / 180), 0.2), 0.0025);

const minLat = clamp(latitude - latSpan / 2, -90, 90);
const maxLat = clamp(latitude + latSpan / 2, -90, 90);
const minLng = clamp(longitude - lonSpan / 2, -180, 180);
const maxLng = clamp(longitude + lonSpan / 2, -180, 180);

const bbox = `${minLng},${minLat},${maxLng},${maxLat}`;
const marker = `${latitude},${longitude}`;
const embedUrl = `https://www.openstreetmap.org/export/embed.html?bbox=${encodeURIComponent(bbox)}&layer=mapnik&marker=${encodeURIComponent(marker)}`;
const openStreetMapUrl = `https://www.openstreetmap.org/?mlat=${latitude}&mlon=${longitude}#map=${safeZoom}/${latitude}/${longitude}`;
const caption = label ?? `${latitude.toFixed(5)}, ${longitude.toFixed(5)}`;
---

<figure class="book-map-marker">
  <div class="map-frame" style={`--map-height:${safeHeight}px;`}>
    <iframe
      title={title}
      src={embedUrl}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>

  <figcaption>
    <span>{caption}</span>
    <a href={openStreetMapUrl} target="_blank" rel="noopener noreferrer">
      Open in OpenStreetMap
    </a>
  </figcaption>
</figure>

<style>
  .book-map-marker {
    margin: 1.5rem 0;
    border: 1px solid var(--gray-200);
    border-radius: var(--border-radius);
    overflow: hidden;
    background: var(--white);
  }

  .map-frame {
    height: var(--map-height);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--gray-100) 85%, white), var(--white));
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  figcaption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1rem;
    font-size: var(--font-size-smaller);
    color: var(--gray-500);
    background: var(--gray-100);
  }

  figcaption a {
    color: var(--color-link);
    text-decoration: none;
    white-space: nowrap;
  }

  figcaption a:hover {
    text-decoration: underline;
  }

  @media screen and (max-width: 640px) {
    figcaption {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>