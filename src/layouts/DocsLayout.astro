---
import BaseLayout from "./BaseLayout.astro";
import BookMenu from "../components/BookMenu.astro";
import BookToc from "../components/BookToc.astro";
import BookHeader from "../components/BookHeader.astro";
import BookFooter from "../components/BookFooter.astro";
import styles from "./layout.module.css";

interface TocEntry {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title?: string;
  description?: string;
  toc?: TocEntry[];
  frontmatter?: {
    title?: string;
    description?: string;
    toc?: TocEntry[];
  };
  prevPage?: { href: string; title: string };
  nextPage?: { href: string; title: string };
  editUrl?: string;
  lastModified?: Date;
}

const {
  title: rawTitle,
  description: rawDescription,
  toc: rawToc,
  frontmatter,
  prevPage,
  nextPage,
  editUrl,
  lastModified,
} = Astro.props;

const title = rawTitle ?? frontmatter?.title;
const description = rawDescription ?? frontmatter?.description;
const toc = rawToc ?? frontmatter?.toc ?? [];
---

<BaseLayout title={title} description={description}>
  <!-- Hidden checkboxes for CSS-only mobile menu / toc toggles -->
  <input
    type="checkbox"
    class="toggle"
    id="menu-control"
  />
  <input type="checkbox" class="toggle" id="toc-control" />

  <main class={`${styles.container} ${styles.flex}`}>
    <!-- Left sidebar -->
    <BookMenu />

    <!-- Main content -->
    <div class={styles.bookPage}>
      <BookHeader title={title} hasToc={toc.length > 0} toc={toc} />

      <article class="markdown">
        <slot />
      </article>

      <BookFooter
        prevPage={prevPage}
        nextPage={nextPage}
        editUrl={editUrl}
        lastModified={lastModified}
      />

      <label for="menu-control" class={styles.bookMenuOverlay}></label>
    </div>

    <!-- Right ToC -->
    {toc.length > 0 && <BookToc toc={toc} />}
  </main>
</BaseLayout>
